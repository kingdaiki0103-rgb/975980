DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000000000/your-webhook-token
DB_PATH=data/notified_jobs.sqlite
MIN_AMOUNT_YEN=3000
DRY_RUN=false
LOG_LEVEL=INFO
REQUEST_DELAY_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=15
MAX_DETAIL_PAGES=20
ALLOW_ON_ROBOTS_UNAVAILABLE=false
# 必要に応じてクラウドワークスの検索URLをカンマ区切りで指定します。
# 未指定の場合は対象キーワードごとに公開検索URLを生成します。
CROWDWORKS_SEARCH_URLS=
